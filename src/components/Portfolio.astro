        >
          <div class="portfolio-content h-100">
            <img
              src="/assets/img/portfolio/books-3.png"
              class="img-fluid"
              alt="Gestión de Almacenes WMS"
            />
            <div class="portfolio-info">
              <h4>Picking con IA</h4>
              <p>Eficiencia máxima en almacenes</p>
              <a
