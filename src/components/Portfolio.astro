---

---

<!-- Portfolio Section -->
<section id="portfolio" class="portfolio section">
  <!-- Section Title -->
  <div class="container section-title" data-aos="fade-up">
    <h2>Proyectos</h2>
    <p>NUESTRO PORTAFOLIO</p>
  </div><!-- End Section Title -->

  <div class="container">
    <div
      class="isotope-layout"
      data-default-filter="*"
      data-layout="masonry"
      data-sort="original-order"
    >
      <ul
        class="portfolio-filters isotope-filters"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <li data-filter="*" class="filter-active">Todos</li>
        <li data-filter=".filter-app">Apps</li>
        <li data-filter=".filter-product">Sistemas</li>
        <li data-filter=".filter-branding">Estrategia</li>
        <li data-filter=".filter-books">Logística</li>
      </ul><!-- End Portfolio Filters -->

      <div
        class="row gy-4 isotope-container"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        <div
          class="col-lg-4 col-md-6 col-6 portfolio-item isotope-item filter-app"
        >
          <div class="portfolio-content h-100">
            <img
              src="/assets/img/portfolio/app-1.png"
              class="img-fluid"
              alt="Desarrollo de Aplicación Móvil - iRiS"
            />
            <div class="portfolio-info">
              <h4>Plataforma Fintech</h4>
              <p>Seguridad y escalabilidad financiera</p>
              <a
                id="portfolio-first-link"
                href="/assets/img/portfolio/app-1.png"
                title="Plataforma Fintech"
                data-gallery="portfolio-gallery"
                class="glightbox preview-link"><i class="bi bi-zoom-in"></i></a
              >
              <a
                href="/portfolio-details/"
                title="More Details"
                class="details-link"><i class="bi bi-link-45deg"></i></a
              >
            </div>
          </div>
        </div><!-- End Portfolio Item -->

        <div
          class="col-lg-4 col-md-6 col-6 portfolio-item isotope-item filter-product"
        >
          <div class="portfolio-content h-100">
            <img
              src="/assets/img/portfolio/product-1.png"
              class="img-fluid"
              alt="Sistema de Gestión Empresarial - iRiS"
            />
            <div class="portfolio-info">
              <h4>Sistema ERP Industrial</h4>
              <p>Control total de procesos operativos</p>
              <a
                href="/assets/img/portfolio/product-1.png"
                title="Sistema ERP Industrial"
                data-gallery="portfolio-gallery"
                class="glightbox preview-link"><i class="bi bi-zoom-in"></i></a
              >
              <a
                href="/portfolio-details/"
                title="More Details"
                class="details-link"><i class="bi bi-link-45deg"></i></a
              >
            </div>
          </div>
        </div><!-- End Portfolio Item -->

        <div
          class="col-lg-4 col-md-6 col-6 portfolio-item isotope-item filter-branding"
        >
          <div class="portfolio-content h-100">
            <img
              src="/assets/img/portfolio/branding-1.png"
              class="img-fluid"
              alt="Consultoría en Estrategia Digital - iRiS"
            />
            <div class="portfolio-info">
              <h4>Consultoría de Innovación</h4>
              <p>Estrategia digital de alto impacto</p>
              <a
