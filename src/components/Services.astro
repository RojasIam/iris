---

---

<!-- Services Section -->
<section id="services" class="services section">
  <!-- Section Title -->
  <div class="container section-title" data-aos="fade-up">
    <h2>Nuestros Pilares</h2>
    <p>Soluciones de Próxima Generación<br /></p>
  </div><!-- End Section Title -->

  <div class="container" data-aos="fade-up" data-aos-delay="100">
    <div class="row gy-5">
      <div class="col-xl-4 col-md-6" data-aos="zoom-in" data-aos-delay="200">
        <div class="service-item">
          <div class="img">
            <img
              src="/assets/img/sistemas-medida.jpg"
              class="img-fluid"
              alt="Sistemas a Medida"
            />
          </div>
          <div class="details position-relative">
            <div class="icon">
              <i class="bi bi-code-slash"></i>
            </div>
            <a href="/service-details/" class="stretched-link">
              <h3>Sistemas & Web a Medida</h3>
            </a>
            <p>
              Desarrollamos ecosistemas complejos y plataformas web escalables
              diseñadas exclusivamente para las necesidades críticas de tu
              empresa.
            </p>
          </div>
        </div>
      </div><!-- End Service Item -->

      <div class="col-xl-4 col-md-6" data-aos="zoom-in" data-aos-delay="300">
        <div class="service-item">
          <div class="img">
            <img
              src="/assets/img/auto-almacenes.jpg"
              class="img-fluid"
              alt="Automatización"
            />
          </div>
          <div class="details position-relative">
            <div class="icon">
              <i class="bi bi-gear-wide-connected"></i>
            </div>
            <a href="/service-details/" class="stretched-link">
              <h3>Automatización & Almacenes</h3>
            </a>
            <p>
              Optimización de la cadena logística y automatización de procesos
              industriales con enfoque en la mejora continua y eficiencia
              operativa.
            </p>
          </div>
        </div>
      </div><!-- End Service Item -->

      <div class="col-xl-4 col-md-6" data-aos="zoom-in" data-aos-delay="400">
        <div class="service-item">
          <div class="img">
            <img
              src="/assets/img/ai-botchat.jpg"
              class="img-fluid"
              alt="IA & Agentes"
            />
          </div>
          <div class="details position-relative">
            <div class="icon">
              <i class="bi bi-cpu"></i>
            </div>
            <a href="/service-details/" class="stretched-link">
              <h3>Agentes de IA & Chatbots</h3>
            </a>
            <p>
              Implementación de inteligencia artificial avanzada y agentes
              autónomos para revolucionar la atención al cliente y la toma de
              decisiones.
            </p>
          </div>
        </div>
      </div><!-- End Service Item -->
    </div>
  </div>
  <style>
    .services .img {
      height: 280px; /* Reducido para un equilibrio perfecto */
      overflow: hidden;
      border-radius: 12px;
    }
    .services .img img {
      width: 100%;
      height: 100%;
      object-fit: cover; /* Clave para que no se vean aplastadas */
      transition: 0.5s;
    }
    .services .service-item:hover .img img {
      transform: scale(1.1);
    }

    @media (max-width: 575px) {
      .services .img {
        height: 350px;
      }
      .services .details {
        margin: -60px 20px 0 20px;
        padding: 40px 20px;
      }
    }
  </style>
</section><!-- /Services Section -->
