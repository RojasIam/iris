---

<!-- Testimonials Section -->
<section id="testimonials" class="testimonials section light-background">
  <div class="container section-title" data-aos="fade-up">
    <h2>Testimonios</h2>
    <p>Lo que dicen nuestros clientes</p>
  </div><!-- End Section Title -->

  <div class="container" data-aos="fade-up" data-aos-delay="100">
    <div class="swiper init-swiper">
      <script type="application/json" class="swiper-config">
        {
          "loop": true,
          "speed": 600,
          "autoplay": {
            "delay": 5000
          },
          "slidesPerView": "auto",
          "pagination": {
            "el": ".swiper-pagination",
            "type": "bullets",
            "clickable": true
          },
          "breakpoints": {
            "320": {
              "slidesPerView": 1,
              "spaceBetween": 40
            },
            "1200": {
              "slidesPerView": 3,
              "spaceBetween": 20
            }
          }
        }
      </script>
      <div class="swiper-wrapper">
        <div class="swiper-slide">
          <div class="testimonial-item">
            <div class="stars">
              <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                class="bi bi-star-fill"></i>
            </div>
            <p>
              <i class="bi bi-quote quote-icon-left"></i>
              <span
                >La implementación del WMS de iRiS transformó nuestra logística.
                Ahora tenemos trazabilidad total y cero errores en despachos.</span
              >
              <i class="bi bi-quote quote-icon-right"></i>
            </p>
            <span class="read-more">Ver más</span>
            <div class="profile mt-auto">
              <img
                src="/assets/img/testimonials/testimonials-1.jpg"
                class="testimonial-img"
                alt="Saul Goodman"
              />
              <div class="profile-info">
                <h3>Ricardo Mendoza</h3>
                <h4>Director Ejecutivo</h4>
              </div>
            </div>
          </div>
        </div><!-- End testimonial item -->

        <div class="swiper-slide">
          <div class="testimonial-item">
            <div class="stars">
              <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                class="bi bi-star-fill"></i>
            </div>
            <p>
              <i class="bi bi-quote quote-icon-left"></i>
              <span
                >Sus agentes de IA no solo responden chats, resuelven problemas
                reales. La eficiencia de nuestro soporte aumentó un 70%.</span
              >
              <i class="bi bi-quote quote-icon-right"></i>
            </p>
            <span class="read-more">Ver más</span>
            <div class="profile mt-auto">
              <img
                src="/assets/img/testimonials/testimonials-2.jpg"
                class="testimonial-img"
                alt="Sara Wilsson"
              />
              <div class="profile-info">
                <h3>Valentina García</h3>
                <h4>Directora Creativa</h4>
              </div>
            </div>
          </div>
        </div><!-- End testimonial item -->

        <div class="swiper-slide">
          <div class="testimonial-item">
            <div class="stars">
              <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                class="bi bi-star-fill"></i>
            </div>
            <p>
              <i class="bi bi-quote quote-icon-left"></i>
              <span
                >El desarrollo a medida que hicieron para nuestra intranet
                superó todas las expectativas. Seguridad robusta y UI impecable.</span
              >
              <i class="bi bi-quote quote-icon-right"></i>
            </p>
            <span class="read-more">Ver más</span>
            <div class="profile mt-auto">
              <img
                src="/assets/img/testimonials/testimonials-3.jpg"
                class="testimonial-img"
                alt="Jena Karlis"
              />
              <div class="profile-info">
                <h3>Ximena Ramos</h3>
                <h4>Gerente de Operaciones</h4>
              </div>
            </div>
          </div>
        </div><!-- End testimonial item -->

        <div class="swiper-slide">
          <div class="testimonial-item">
            <div class="stars">
              <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                class="bi bi-star-fill"></i>
            </div>
            <p>
              <i class="bi bi-quote quote-icon-left"></i>
              <span
                >Trabajar con iRiS es tener un equipo de ingeniería de élite a
                tu disposición. Su enfoque en resultados es real.</span
              >
              <i class="bi bi-quote quote-icon-right"></i>
            </p>
            <span class="read-more">Ver más</span>
            <div class="profile mt-auto">
              <img
                src="/assets/img/testimonials/testimonials-4.jpg"
                class="testimonial-img"
                alt="Matt Brandon"
              />
              <div class="profile-info">
                <h3>Mateo Torres</h3>
                <h4>Consultor Senior</h4>
              </div>
            </div>
          </div>
        </div><!-- End testimonial item -->

        <div class="swiper-slide">
          <div class="testimonial-item">
            <div class="stars">
              <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                class="bi bi-star-fill"></i>
            </div>
            <p>
              <i class="bi bi-quote quote-icon-left"></i>
              <span
                >La consultoría cloud de iRiS nos permitió migrar sin fricciones
                y optimizar costos operativos significativamente.</span
              >
              <i class="bi bi-quote quote-icon-right"></i>
            </p>
            <span class="read-more">Ver más</span>
            <div class="profile mt-auto">
              <img
                src="/assets/img/testimonials/testimonials-5.jpg"
                class="testimonial-img"
                alt="John Larson"
              />
              <div class="profile-info">
                <h3>Juan Carlos Pérez</h3>
                <h4>Emprendedor Digital</h4>
              </div>
            </div>
          </div>
        </div><!-- End testimonial item -->
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>

  <style>
    .testimonials .testimonial-item {
      box-sizing: border-box;
      padding: 25px;
      margin: 20px 10px;
      height: 260px; /* Altura más compacta para evitar vacíos excesivos */
      box-shadow: 0px 5px 20px rgba(0, 0, 0, 0.05);
      position: relative;
      background: #fff;
      border-radius: 12px;
      display: flex;
      flex-direction: column;
      transition: all 0.3s ease;
      border: 1px solid
        color-mix(in srgb, var(--default-color), transparent 96%);
    }

    .testimonials .testimonial-item:hover {
      transform: translateY(-5px);
      box-shadow: 0px 10px 30px rgba(15, 87, 135, 0.1);
      border-color: var(--accent-color);
    }

    .testimonials .testimonial-item .stars {
      margin-bottom: 10px;
    }

    .testimonials .testimonial-item .stars i {
      color: #ffc107;
      font-size: 14px;
    }

    .testimonials .testimonial-item p {
      font-style: italic;
      margin: 0;
      color: var(--default-color);
      line-height: 1.5;
      font-size: 14px;
      display: -webkit-box;
      -webkit-line-clamp: 4; /* Limitamos a 4 líneas */
      -webkit-box-orient: vertical;
      overflow: hidden;
      position: relative;
    }

    .testimonials .testimonial-item .read-more {
      color: var(--accent-color);
      font-weight: 600;
      font-size: 12px;
      text-transform: uppercase;
      margin-top: 5px;
      cursor: pointer;
      display: inline-block;
    }

    .testimonials .testimonial-item .profile {
      display: flex;
      align-items: center;
      margin-top: auto;
      padding-top: 15px;
      border-top: 1px dashed
        color-mix(in srgb, var(--default-color), transparent 90%);
    }

    .testimonials .testimonial-item .testimonial-img {
      width: 45px;
      height: 45px;
      border-radius: 50%;
      margin-right: 12px;
      object-fit: cover;
    }

    .testimonials .testimonial-item h3 {
      font-size: 15px;
      font-weight: 700;
      margin: 0;
      color: var(--heading-color);
    }

    .testimonials .testimonial-item h4 {
      font-size: 12px;
      color: color-mix(in srgb, var(--default-color), transparent 60%);
      margin: 0;
    }

    .testimonials .swiper-pagination {
      margin-top: 20px;
      position: relative;
    }

    .testimonials .swiper-pagination .swiper-pagination-bullet {
      width: 10px;
      height: 10px;
      background-color: color-mix(
        in srgb,
        var(--default-color),
        transparent 80%
      );
      opacity: 0.5;
    }

    .testimonials .swiper-pagination .swiper-pagination-bullet-active {
      background-color: var(--accent-color);
      opacity: 1;
    }

    @media (max-width: 768px) {
      .testimonials .testimonial-item {
        height: auto;
        min-height: 280px;
      }
    }
  </style>
</section><!-- /Testimonials Section -->
